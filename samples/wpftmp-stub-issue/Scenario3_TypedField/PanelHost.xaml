<!--
  SCENARIO 3 — Event subscription on x:Name field typed as 'dynamic' (CS0019 / CS1977)

  This window has an x:Name'd ListView.
  WXSG generates a stub for PanelHost that declares the field for 'listView'.

  BEFORE fix (field typed as 'dynamic'):
    PanelHost.xaml.cs(22,13): error CS0019 — '+=' cannot be applied to 'dynamic' and 'anonymous method'
      (because listView was typed as dynamic in the stub)
    PanelHost.xaml.cs(28,13): error CS1977 — cannot use lambda with dynamically dispatched operation
      (same cause)

  AFTER fix (fields use actual WPF CLR types from wpfTypeMap):
    'listView' → global::System.Windows.Controls.ListView

  Note: this scenario uses only standard WPF types (no local clr-namespace: references)
  so that the net10.0-windows WXSG pass succeeds and proves the XAML content is correct.
  The net48 _wpftmp build still fails because GenerateTemporaryTargetAssembly does not
  include WXSG-generated stubs in the temporary project.
-->
<Window x:Class="WpfTmpStubIssue.Scenario3_TypedField.PanelHost"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PanelHost" Height="300" Width="400">
    <ListView x:Name="listView" />
</Window>
