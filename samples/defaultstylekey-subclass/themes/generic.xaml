<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:DefaultStyleKeySubclassSample;assembly=DefaultStyleKeySubclassSample">

    <!-- Default style for CustomTextBox, applied via DefaultStyleKey.
         Loaded into Application.Resources by WXSG's __WxsgThemeLoader module initializer. -->
    <Style TargetType="{x:Type local:CustomTextBox}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:CustomTextBox}">
                    <Border Background="LightYellow"
                            BorderBrush="Orange"
                            BorderThickness="2"
                            CornerRadius="3">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="4,2" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
