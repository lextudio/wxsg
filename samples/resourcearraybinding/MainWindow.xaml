<Window x:Class="ResourceArrayBindingSample.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ResourceArrayBindingSample"
        Title="Resource Array Binding Sample" Height="220" Width="360">
    <Window.Resources>
        <ResourceDictionary>
            <x:Array x:Key="toolBoxItems" Type="local:ToolBoxItem">
                <local:ToolBoxItem Name="Button" />
                <local:ToolBoxItem Name="TextBox" />
            </x:Array>
        </ResourceDictionary>
    </Window.Resources>

    <ListBox DisplayMemberPath="Name"
             ItemsSource="{Binding Source={StaticResource toolBoxItems}}" />
</Window>
